&inputpp
outdir = './tmp'
prefix= 'LiCu2O2'
seedname= 'LiCu2O2'
               !spin_component = 'up'
               write_mmn = .true.
               write_amn = .true.
               write_unk = .false.

               write_dmn = .false.
               write_spn = .false.
               !read_sym = .true.
               wan_mode = 'standalone'
          /

