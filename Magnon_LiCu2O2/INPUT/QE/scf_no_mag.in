&control
    calculation = 'scf'
    restart_mode = 'from_scratch'
    wf_collect = .true.
    prefix = 'LiCu2O2'
    pseudo_dir = '/home/chen/PP/'
    outdir = './tmp'
    verbosity='high'
 /
&SYSTEM
  ibrav = 8
 celldm(1) =     10.56998456
 celldm(2) =      0.50453324
 celldm(3) =      2.16970595
  !noncolin=.true.
  !lspinorb=.true.
  nat = 20
  ntyp = 3
  ecutwfc = 95
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.01
  !starting_magnetization(1)= 0.5,
  !starting_magnetization(2)= 0.3,
  !starting_magnetization(3)= 0.1,
  !angle1(1)=90.0
  !angle1(2)=90.0
  !angle1(3)=90.0
  !angle2(1)=0.0
  !angle2(2)=0.0
  !angle2(3)=0.0
  nbnd=249
  nr1=72
  nr2=36
  nr3=144
 /
 &electrons
    diago_full_acc = .true.
    conv_thr = 1000
    !mixing_beta = 0.04
    startingpot='file'
/
&ions
/
&cell
   press_conv_thr = 0.001
   cell_dofree='ibrav'
/
