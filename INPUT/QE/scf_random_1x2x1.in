&control
    calculation = 'scf'
    restart_mode = 'from_scratch'
    wf_collect = .true.
    prefix = 'LiCu2O2'
    pseudo_dir = '/home/chen/PP/'
    outdir = './tmp'
    verbosity='high'
 /
&SYSTEM
  ibrav = 8
 celldm(1) =     10.56998456
 celldm(2) =      1.00906648
 celldm(3) =      2.16970595
  noncolin=.true.
  lspinorb=SOC_TF
  nat = 40
  ntyp = 11
  ecutwfc = 95
  occupations = 'smearing'
  smearing = 'gaussian'
  degauss = 0.01
  starting_magnetization(1)= 0.5,
  starting_magnetization(2)= 0.5,
  starting_magnetization(3)= 0.5,
  starting_magnetization(4)= 0.5,
  starting_magnetization(5)= 0.5,
  starting_magnetization(6)= 0.5,
  starting_magnetization(7)= 0.5,
  starting_magnetization(8)= 0.5,
  starting_magnetization(9)= 0.01,
  starting_magnetization(10)= 0.001,
  starting_magnetization(11)= 0.001,
  angle1(1)=Ang1_1
  angle1(2)=Ang2_1
  angle1(3)=Ang3_1
  angle1(4)=Ang4_1
  angle1(5)=Ang5_1
  angle1(6)=Ang6_1
  angle1(7)=Ang7_1
  angle1(8)=Ang8_1
  angle2(1)=Ang1_2
  angle2(2)=Ang2_2
  angle2(3)=Ang3_2
  angle2(4)=Ang4_2
  angle2(5)=Ang5_2
  angle2(6)=Ang6_2
  angle2(7)=Ang7_2
  angle2(8)=Ang8_2
  nbnd=540
  nr1=72
  nr2=72
  nr3=144
  constrained_magnetization='atomic direction'
  lambda=change_lambda
 /
 &electrons
    diago_full_acc = .true.
    conv_thr = 5.0d-change_conv
    mixing_beta = 0.change_beta
 startingpot='change_pot'
/
&ions
/
&cell
   press_conv_thr = 0.001
   cell_dofree='ibrav'
/
